{
  "name": "atlantis-azores",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:host": "pnpm --filter host run dev",
    "dev:remote": "pnpm --filter remote run dev",
    "build": "pnpm --filter remote run build && pnpm --filter host run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "packageManager": "pnpm@9.12.0"
}
